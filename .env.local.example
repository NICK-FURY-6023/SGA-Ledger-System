# ─── JWT Auth ───
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRY=24h

# ─── Firebase Admin SDK (Server-Side) ───
# Get these from: Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── App URL (for OG meta tags) ───
NEXT_PUBLIC_URL=https://sga-ledger-system.vercel.app

# ─── Upstash Redis (for uptime/monitoring data — keeps Firestore free for ledger) ───
# Get these from: https://console.upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token
